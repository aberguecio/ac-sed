# Database
DATABASE_URL=postgresql://acsed:changeme@db:5432/acsed
POSTGRES_DB=acsed
POSTGRES_USER=acsed
POSTGRES_PASSWORD=changeme

# NextAuth
NEXTAUTH_SECRET=replace-with-random-secret-32-chars
NEXTAUTH_URL=http://localhost:3000

# Admin panel
ADMIN_PASSWORD=changeme

# AI Configuration (OpenAI-compatible API)
AI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini          # optional — default: gpt-4o-mini
AI_BASE_URL=                  # optional — for LiteLLM/custom (e.g., http://localhost:4000)

# Cron security
CRON_SECRET=replace-with-random-secret

# AWS (SES para newsletter + S3 para imágenes)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=newsletter@acsed.cl
AWS_S3_BUCKET=acsed-news-images

# URL pública del sitio (usada en links del newsletter)
NEXT_PUBLIC_SITE_URL=https://acsed.cl

# Instagram (Meta Graph API - Content Publishing)
# Long-lived User Access Token (válido ~60 días, renovar antes de que expire)
INSTAGRAM_ACCESS_TOKEN=
# ID numérico de la cuenta Instagram Business/Creator
# Obtenerlo con: GET https://graph.instagram.com/me?access_token=TU_TOKEN
INSTAGRAM_USER_ID=
