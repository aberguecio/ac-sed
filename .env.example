# Database
DATABASE_URL=postgresql://acsed:changeme@db:5432/acsed
POSTGRES_DB=acsed
POSTGRES_USER=acsed
POSTGRES_PASSWORD=changeme

# NextAuth
NEXTAUTH_SECRET=replace-with-random-secret-32-chars
NEXTAUTH_URL=http://localhost:3001

# Admin panel
ADMIN_PASSWORD=changeme

# AI Configuration
# Per-channel provider/model is configured from /admin/ai-config and stored
# in the AiChannelConfig table. The keys below feed each provider's branch
# in lib/ai-config.ts:getModelForChannel(). Only set the keys for providers
# you actually plan to use.

# OpenAI (default provider for all channels on first boot)
OPENAI_API_KEY=sk-...
# Legacy alias — still read as fallback if OPENAI_API_KEY is unset
AI_API_KEY=
# Optional — point at LiteLLM/custom OpenAI-compatible gateway when provider=openai
AI_BASE_URL=

# Anthropic — only needed if a channel is set to provider=anthropic
ANTHROPIC_API_KEY=

# DeepSeek (OpenAI-compatible, https://api.deepseek.com/v1)
# Only needed if a channel is set to provider=deepseek
DEEPSEEK_API_KEY=

# MiniMax (OpenAI-compatible, https://api.minimax.io/v1)
# Only needed if a channel is set to provider=minimax
MINIMAX_API_KEY=

# Cron security
CRON_SECRET=replace-with-random-secret

# AWS (SES para newsletter + S3 para imágenes)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=newsletter@acsed.cl
AWS_S3_BUCKET=acsed-news-images

# URL pública del sitio (usada en links del newsletter)
NEXT_PUBLIC_SITE_URL=https://acsed.cl

# WhatsApp (Evolution API) — encuestas de asistencia
EVOLUTION_API_URL=https://evolution.berguecio.cl
EVOLUTION_API_KEY=
# Nombre de la instancia configurada en el dashboard de Evolution (p. ej. "Schop")
EVOLUTION_INSTANCE=
WHATSAPP_WEBHOOK_SECRET=replace-with-random-secret
# JID del grupo de WhatsApp al que se envía el resumen de asistencia
# (formato "<group-id>@g.us"). Si está vacío, el resumen no se envía.
# El bot AI también solo responde dentro de este grupo.
WHATSAPP_ATTENDANCE_GROUP_JID=
# JID del propio bot (formato "<phone>@s.whatsapp.net"). Se usa para detectar
# cuándo te mencionan en el grupo. Sin esto, el bot AI no responde.
WHATSAPP_BOT_JID=
