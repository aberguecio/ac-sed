FROM node:20-slim

RUN apt-get update && apt-get install -y \
  chromium \
  libnspr4 \
  libnss3 \
  libatk1.0-0 \
  libatk-bridge2.0-0 \
  libcups2 \
  libdrm2 \
  libxkbcommon0 \
  libxcomposite1 \
  libxdamage1 \
  libxfixes3 \
  libxrandr2 \
  libgbm1 \
  libpango-1.0-0 \
  libcairo2 \
  libasound2 \
  fontconfig \
  fonts-liberation \
  --no-install-recommends \
  && rm -rf /var/lib/apt/lists/*

ENV PLAYWRIGHT_BROWSERS_PATH=/usr/bin
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Register Google Fonts for Instagram image generation (librsvg needs fontconfig).
# TTFs are committed under public/fonts/; kept in sync with lib/fonts.ts.
COPY public/fonts/ /usr/share/fonts/truetype/acsed/
RUN fc-cache -f -v && \
    fc-list | grep -iE 'boldonse|stalinist' || true

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY prisma ./prisma
RUN npx prisma generate

EXPOSE 3000
ENV NODE_ENV=development

CMD ["sh", "-c", "npx prisma db push && npm run dev"]
