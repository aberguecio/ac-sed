generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Match {
  id            Int           @id @default(autoincrement())
  tournamentId  Int?
  stageId       Int?
  groupId       Int?
  date          DateTime
  homeTeam      String
  awayTeam      String
  homeScore     Int?
  awayScore     Int?
  roundName     String?
  leagueMatchId String?       @unique
  scrapedAt     DateTime      @default(now())
  news          NewsArticle[]
  goals         MatchGoal[]
  cards         MatchCard[]

  @@index([tournamentId, stageId, groupId])
}

model Standing {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  stageId      Int
  groupId      Int
  groupName    String
  teamName     String
  position     Int
  played       Int
  won          Int
  drawn        Int
  lost         Int
  goalsFor     Int
  goalsAgainst Int
  points       Int
  updatedAt    DateTime @updatedAt

  @@unique([tournamentId, stageId, groupId, teamName])
  @@index([tournamentId, stageId, groupId])
}

model LeagueScorer {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  playerName   String
  teamName     String
  goals        Int
  updatedAt    DateTime @updatedAt

  @@index([tournamentId])
}

model Player {
  id               Int            @id @default(autoincrement())
  name             String
  position         String?
  number           Int?
  photoUrl         String?
  bio              String?
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  // Hexagonal stats (0-99, like FIFA)
  statRitmo        Int?
  statDisparo      Int?
  statPase         Int?
  statRegate       Int?
  statDefensa      Int?
  statFisico       Int?
  // Link to scraped player data
  leaguePlayerId   Int?           @unique // ID from Liga B API
  goals            MatchGoal[]
  cards            MatchCard[]
}

// Scraped player from Liga B API (not our roster)
model ScrapedPlayer {
  id            Int         @id // Liga B API player ID
  firstName     String
  lastName      String
  email         String?
  run           String?
  teamId        Int?
  teamName      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  goals         MatchGoal[]
  cards         MatchCard[]

  @@index([teamId])
  @@index([teamName])
}

model NewsArticle {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  content     String
  imageUrl    String?
  matchId     Int?
  aiProvider  String
  generatedAt DateTime  @default(now())
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  emailSentAt DateTime?
  match       Match?    @relation(fields: [matchId], references: [id], onDelete: SetNull)
}

model NewsletterSubscriber {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  unsubscribeToken String   @unique @default(cuid())
  subscribedAt     DateTime @default(now())
  active           Boolean  @default(true)
}

model ScrapeLog {
  id           Int       @id @default(autoincrement())
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String
  matchesFound Int?
  errorMessage String?
  triggeredBy  String
}

model TournamentAnalysis {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  stageId      Int
  groupId      Int
  content      String   @db.Text
  dataHash     String   // Hash de los datos para detectar cambios
  aiProvider   String?
  generatedAt  DateTime @default(now())

  @@unique([tournamentId, stageId, groupId])
  @@index([tournamentId, stageId])
}

model MatchGoal {
  id              Int            @id @default(autoincrement())
  matchId         Int
  leaguePlayerId  Int            // Player ID from Liga B API
  minute          Int?
  teamName        String
  createdAt       DateTime       @default(now())
  match           Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scrapedPlayer   ScrapedPlayer  @relation(fields: [leaguePlayerId], references: [id], onDelete: Cascade)
  // Optional link to our roster player
  rosterPlayer    Player?        @relation(fields: [rosterPlayerId], references: [id], onDelete: SetNull)
  rosterPlayerId  Int?

  @@unique([matchId, leaguePlayerId])
  @@index([leaguePlayerId])
  @@index([rosterPlayerId])
}

model MatchCard {
  id              Int            @id @default(autoincrement())
  matchId         Int
  leaguePlayerId  Int            // Player ID from Liga B API
  cardType        String         // 'yellow' or 'red'
  minute          Int?
  reason          String?
  teamName        String
  createdAt       DateTime       @default(now())
  match           Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scrapedPlayer   ScrapedPlayer  @relation(fields: [leaguePlayerId], references: [id], onDelete: Cascade)
  // Optional link to our roster player
  rosterPlayer    Player?        @relation(fields: [rosterPlayerId], references: [id], onDelete: SetNull)
  rosterPlayerId  Int?

  @@index([matchId])
  @@index([leaguePlayerId])
  @@index([rosterPlayerId])
}
