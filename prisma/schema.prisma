generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tournament {
  id        Int      @id // Liga B API tournament ID
  name      String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stages    Stage[]
  matches   Match[]
  standings Standing[]
  scorers   LeagueScorer[]
  analyses  TournamentAnalysis[]

  @@index([isActive])
}

model Stage {
  id           Int        @id // Liga B API stage ID
  tournamentId Int
  name         String?
  orderIndex   Int        @default(0) // Para ordenar las fases
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  groups       Group[]
  matches      Match[]

  @@index([tournamentId])
  @@index([tournamentId, orderIndex])
}

model Group {
  id        Int      @id // Liga B API group ID
  stageId   Int
  name      String   // "Thor", "Loki", etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stage     Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  matches   Match[]
  standings Standing[]

  @@index([stageId])
}

model Team {
  id           Int      @id // Liga B API team ID
  name         String
  logoUrl      String?  // Base URL sin el prefijo de tamaño (e.g., "UUID.jpeg")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  homeMatches  Match[]  @relation("HomeTeam")
  awayMatches  Match[]  @relation("AwayTeam")
  standings    Standing[]
  scorers      LeagueScorer[]

  @@index([name])
}

model Match {
  id            Int           @id @default(autoincrement())
  tournamentId  Int?
  stageId       Int?
  groupId       Int?
  date          DateTime
  venue         String?       // Cancha (mapeado desde "grounds" en la API)
  homeTeamId    Int?
  awayTeamId    Int?
  homeScore     Int?
  awayScore     Int?
  roundName     String?
  leagueMatchId String?       @unique
  scrapedAt     DateTime      @default(now())
  news           NewsArticle[]
  instagramPosts InstagramPost[]
  goals          MatchGoal[]
  cards          MatchCard[]

  // Relations
  tournament    Tournament?   @relation(fields: [tournamentId], references: [id])
  stage         Stage?        @relation(fields: [stageId], references: [id])
  group         Group?        @relation(fields: [groupId], references: [id])
  homeTeam      Team?         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team?         @relation("AwayTeam", fields: [awayTeamId], references: [id])

  @@index([tournamentId, stageId, groupId])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model Standing {
  id           Int         @id @default(autoincrement())
  tournamentId Int
  stageId      Int
  groupId      Int
  teamId       Int
  position     Int
  played       Int
  won          Int
  drawn        Int
  lost         Int
  goalsFor     Int
  goalsAgainst Int
  points       Int
  updatedAt    DateTime    @updatedAt

  // Relations
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
  group        Group?      @relation(fields: [groupId], references: [id])
  team         Team        @relation(fields: [teamId], references: [id])

  @@unique([tournamentId, stageId, groupId, teamId])
  @@index([tournamentId, stageId, groupId])
  @@index([teamId])
}

model LeagueScorer {
  id           Int         @id @default(autoincrement())
  tournamentId Int
  playerName   String
  teamId       Int
  goals        Int
  updatedAt    DateTime    @updatedAt

  // Relations
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
  team         Team        @relation(fields: [teamId], references: [id])

  @@index([tournamentId])
  @@index([teamId])
}

model Player {
  id               Int            @id @default(autoincrement())
  name             String
  position         String?
  number           Int?
  photoUrl         String?
  bio              String?
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  // Hexagonal stats (0-99, like FIFA)
  statRitmo        Int?
  statDisparo      Int?
  statPase         Int?
  statRegate       Int?
  statDefensa      Int?
  statFisico       Int?
  // Link to scraped player data
  leaguePlayerId   Int?           @unique // ID from Liga B API
  goals            MatchGoal[]
  cards            MatchCard[]
}

// Scraped player from Liga B API (not our roster)
model ScrapedPlayer {
  id            Int         @id // Liga B API player ID
  firstName     String
  lastName      String
  email         String?
  run           String?
  teamId        Int?
  teamName      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  goals         MatchGoal[]
  cards         MatchCard[]

  @@index([teamId])
  @@index([teamName])
}

model NewsArticle {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  content     String
  imageUrl    String?
  matchId     Int?
  aiProvider  String
  generatedAt DateTime  @default(now())
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  emailSentAt DateTime?
  match       Match?    @relation(fields: [matchId], references: [id], onDelete: SetNull)
}

model NewsletterSubscriber {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  unsubscribeToken String   @unique @default(cuid())
  subscribedAt     DateTime @default(now())
  active           Boolean  @default(true)
}

model ScrapeLog {
  id              Int       @id @default(autoincrement())
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  status          String    // 'running', 'success', 'error'
  tournamentId    Int?
  tournamentName  String?
  stageIds        String?   // JSON array of stage IDs processed
  matchesFound    Int?
  newMatches      Int?      // New matches added
  updatedMatches  Int?      // Existing matches updated
  teamsProcessed  Int?
  standingsSaved  Int?
  groupsFound     Int?
  errorMessage    String?
  detailedLog     String?   @db.Text // Detailed logs from console
  triggeredBy     String

  @@index([status])
  @@index([startedAt])
}

model TournamentAnalysis {
  id           Int         @id @default(autoincrement())
  tournamentId Int
  stageId      Int
  groupId      Int
  content      String      @db.Text
  dataHash     String      // Hash de los datos para detectar cambios
  aiProvider   String?
  generatedAt  DateTime    @default(now())

  // Relations
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])

  @@unique([tournamentId, stageId, groupId])
  @@index([tournamentId, stageId])
}

model MatchGoal {
  id              Int            @id @default(autoincrement())
  matchId         Int
  leaguePlayerId  Int            // Player ID from Liga B API
  minute          Int?
  teamName        String
  createdAt       DateTime       @default(now())
  match           Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scrapedPlayer   ScrapedPlayer  @relation(fields: [leaguePlayerId], references: [id], onDelete: Cascade)
  // Optional link to our roster player
  rosterPlayer    Player?        @relation(fields: [rosterPlayerId], references: [id], onDelete: SetNull)
  rosterPlayerId  Int?

  @@index([matchId])
  @@index([leaguePlayerId])
  @@index([rosterPlayerId])
}

model MatchCard {
  id              Int            @id @default(autoincrement())
  matchId         Int
  leaguePlayerId  Int            // Player ID from Liga B API
  cardType        String         // 'yellow' or 'red'
  minute          Int?
  reason          String?
  teamName        String
  createdAt       DateTime       @default(now())
  match           Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scrapedPlayer   ScrapedPlayer  @relation(fields: [leaguePlayerId], references: [id], onDelete: Cascade)
  // Optional link to our roster player
  rosterPlayer    Player?        @relation(fields: [rosterPlayerId], references: [id], onDelete: SetNull)
  rosterPlayerId  Int?

  @@index([matchId])
  @@index([leaguePlayerId])
  @@index([rosterPlayerId])
}

model InstagramBackground {
  id        Int      @id @default(autoincrement())
  name      String
  imageUrl  String
  createdAt DateTime @default(now())
}

model InstagramPost {
  id           Int                  @id @default(autoincrement())
  caption      String               @db.Text
  postType     String               @default("result") // result | promo | custom
  matchId      Int?
  igMediaId    String?              @unique
  status       String               @default("draft") // draft | publishing | published | failed
  errorMessage String?
  publishedAt  DateTime?
  aiProvider   String?
  generatedAt  DateTime             @default(now())

  // Relations
  match        Match?               @relation(fields: [matchId], references: [id], onDelete: SetNull)
  images       InstagramPostImage[]

  @@index([matchId])
  @@index([status])
}

model InstagramPostImage {
  id            Int           @id @default(autoincrement())
  postId        Int
  imageUrl      String        // Final composed image URL on S3 (JPEG)
  backgroundUrl String?       // Original background (template or custom upload)
  orderIndex    Int           @default(0)

  // Relations
  post          InstagramPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}
